---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { projects, workExperience, socialLinks, techStack, focusAreas } from '../data/site-data';
import { getSortedPosts } from '../lib/hashnode/client';
import { formatMonthYear } from '../lib/date/format-date';

const featuredProjects = projects.filter((p) => p.featured);
const hashnodePosts = await getSortedPosts();
const recentPosts = hashnodePosts.slice(0, 4);
const leadsApiUrl = import.meta.env.PUBLIC_LEADS_API_URL?.trim() ?? '';
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY?.trim() ?? '';
---

<BaseLayout title="Akash R Chandran — Backend Engineer" description="Backend Engineer focused on building fast, reliable, and secure backend systems at production scale.">
  <div class="min-h-screen bg-background text-foreground relative">
    <Header />

    <main class="max-w-6xl mx-auto px-6 sm:px-8 pt-24">
      <!-- Hero / Intro -->
      <header
        id="intro"
        class="min-h-[88vh] flex items-center opacity-0 animate-section"
      >
        <div class="w-full grid lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] gap-10 lg:gap-12 items-stretch">
          <div class="space-y-7 max-w-3xl lg:min-h-[72vh] lg:flex lg:flex-col lg:justify-center">
            <div class="space-y-4">
              <h1 class="text-6xl sm:text-7xl lg:text-[5.2rem] font-light tracking-tight leading-tight">
                Akash R
                <br />
                <span class="text-brand">Chandran</span>
              </h1>
            </div>

            <p class="text-lg sm:text-xl text-muted-foreground leading-relaxed max-w-xl">
              Backend Engineer building <span class="text-foreground font-medium">fast</span>, <span class="text-foreground font-medium">reliable</span>, and <span class="text-foreground font-medium">secure</span> backend systems that scale in production.
            </p>

            <div class=" bg-muted/10 space-y-4 max-w-xl">
              <div>
                <div class="text-xs text-muted-foreground font-mono tracking-widest mb-3">CURRENTLY</div>
                <div class="space-y-1">
                  <div class="text-foreground font-medium">Associate Engineer (R&D)</div>
                  <div class="text-muted-foreground text-sm">Litmus7 Systems Consulting Pvt Ltd</div>
                  
                  <div class="text-xs text-muted-foreground">Jul 2024 — Present</div>
                </div>
              </div>

              <div class="flex items-center gap-2 text-sm text-muted-foreground">
                <div class="w-2 h-2 bg-[color:var(--brand)] rounded-full animate-pulse"></div>
                Available for work
              </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
              <button id="openLeadModal" type="button" class="px-5 py-2.5 rounded-lg border border-brand bg-brand text-sm text-white transition-all duration-300 hover:bg-[color:var(--brand-hover)] shadow-[0_0_24px_-12px_var(--brand-glow)] hover:shadow-[0_0_28px_-10px_var(--brand-glow)]">
                View Resume
              </button>
              <a href="#connect" class="px-5 py-2.5 rounded-lg border border-brand bg-brand-soft hover:bg-[color:var(--brand-soft-strong)] transition-all duration-300 text-sm text-brand">
                Contact
              </a>
            </div>
          </div>

          <div class="space-y-6 lg:min-h-[72vh] lg:flex lg:flex-col lg:justify-center">
            <div class="bg-muted/10 space-y-5">
              <div class="text-xs text-muted-foreground font-mono tracking-widest">BACKEND STACK</div>
              <div class="flex flex-wrap gap-2">
                {techStack.map((skill) => (
                  <span class="px-3 py-1.5 text-xs border border-border rounded-full hover:border-muted-foreground/60 transition-all duration-300 bg-background/50 hover:bg-background">
                    {skill}
                  </span>
                ))}
              </div>

              <div class="pt-5 space-y-3">
                <div class="text-xs text-muted-foreground font-mono tracking-widest">FOCUS</div>
                <ul class="space-y-2 text-sm text-muted-foreground list-disc ml-4">
                  {focusAreas.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- Work Experience -->
      <section
        id="work"
        class="pt-20 sm:pt-32 opacity-0 animate-section"
      >
        <div class="space-y-12 sm:space-y-16">
          <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
            <h2 class="text-4xl sm:text-5xl font-light tracking-tight"><span class="text-brand">Work</span> Experience</h2>
            <div class="text-sm text-muted-foreground font-mono">2023 — Present</div>
          </div>

          <div class="space-y-1">
            {workExperience.map((job) => (
              <div class="group px-0 py-6 sm:py-8 border-b border-border/40 hover:border-border/80 transition-all duration-300 cursor-pointer">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                  <div class="flex-1 space-y-3">
                    <div class="flex items-baseline gap-3">
                      <h3 class="text-lg sm:text-xl font-medium group-hover:text-muted-foreground transition-colors duration-300">{job.role}</h3>
                      <span class="text-sm text-muted-foreground font-medium">{job.company}</span>
                    </div>
                    <p class="text-muted-foreground text-sm leading-relaxed max-w-2xl">{job.description}</p>
                  </div>
                  
                  <div class="flex items-center gap-4 shrink-0">
                    <span class="text-muted-foreground font-light">{job.year} — {job.endYear ?? 'Present'}</span>
                  </div>
                </div>
                
                <div class="flex flex-wrap gap-2 mt-4">
                  {job.tech.map((tech) => (
                    <span class="px-2 py-1 text-xs text-muted-foreground bg-muted/20 rounded group-hover:bg-muted/40 transition-colors duration-300">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Featured Projects -->
      <section
        id="projects"
        class="pt-20 sm:pt-32 opacity-0 animate-section"
      >
        <div class="space-y-12 sm:space-y-16">
          <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
            <h2 class="text-4xl sm:text-5xl font-light tracking-tight"><span class="text-brand">Featured</span> Projects</h2>
            <a href="/projects" class="text-sm text-muted-foreground hover:text-foreground transition-colors duration-300">
              View all →
            </a>
          </div>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {featuredProjects.map((project) => (
              <div class="group p-6 sm:p-8 border border-border/40 rounded-xl hover:border-border transition-all duration-300 hover:bg-muted/20 space-y-4">
                <div class="space-y-2">
                  <h3 class="text-lg font-medium group-hover:text-muted-foreground transition-colors duration-300">
                    {project.title}
                  </h3>
                  <p class="text-sm text-muted-foreground leading-relaxed">
                    {project.description}
                  </p>
                </div>

                <div class="flex flex-wrap gap-2">
                  {project.technologies.slice(0, 3).map((tech) => (
                    <span class="px-2 py-1 text-xs bg-muted/30 rounded text-muted-foreground">
                      {tech}
                    </span>
                  ))}
                  {project.technologies.length > 3 && (
                    <span class="px-2 py-1 text-xs bg-muted/30 rounded text-muted-foreground">
                      +{project.technologies.length - 3}
                    </span>
                  )}
                </div>

                <div class="flex gap-2 pt-2">
                  {project.link && (
                    <a
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex-1 px-3 py-2 text-xs rounded-lg border border-border/40 hover:border-border text-center text-muted-foreground hover:text-foreground transition-all duration-300"
                    >
                      Live
                    </a>
                  )}
                  {project.github && (
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex-1 px-3 py-2 text-xs rounded-lg border border-border/40 hover:border-border text-center text-muted-foreground hover:text-foreground transition-all duration-300"
                    >
                      GitHub
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Blog / Thoughts -->
      <section
        id="thoughts"
        class="pt-20 sm:pt-32 opacity-0 animate-section"
      >
        <div class="space-y-12 sm:space-y-16">
          <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
            <h2 class="text-4xl sm:text-5xl font-light tracking-tight"><span class="text-brand">Recent</span> Blogs</h2>
            <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground transition-colors duration-300">
              View all →
            </a>
          </div>

          <div class="grid gap-6 sm:gap-8 lg:grid-cols-2">
            {recentPosts.length ? (
              recentPosts.map((post) => (
                <a href={`/blog/${post.slug}`} class="group">
                  <article class="h-full p-6 sm:p-8 border border-border/40 rounded-xl hover:border-border transition-all duration-300 hover:shadow-md cursor-pointer hover:bg-muted/20 space-y-4">
                    <div class="space-y-4">
                      <div class="flex items-center justify-between text-xs text-muted-foreground font-mono">
                        <span>{formatMonthYear(post.publishedAt)}</span>
                        <span>{post.readTimeInMinutes} min</span>
                      </div>

                      <h3 class="text-lg sm:text-xl font-medium leading-tight group-hover:text-muted-foreground transition-colors duration-300">
                        {post.title}
                      </h3>

                      <p class="text-muted-foreground text-sm leading-relaxed">
                        {post.brief || post.subtitle || 'Read the full article for implementation details and engineering trade-offs.'}
                      </p>

                      <div class="flex items-center gap-2 text-sm text-muted-foreground group-hover:text-foreground transition-colors duration-300 pt-2">
                        <span>Read</span>
                        <svg
                          class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"
                          />
                        </svg>
                      </div>
                    </div>
                  </article>
                </a>
              ))
            ) : (
              <div class="lg:col-span-2 p-6 sm:p-8 border border-border/40 rounded-xl text-sm text-muted-foreground">
                Set HASHNODE_PUBLICATION_HOST to load posts from Hashnode.
              </div>
            )}
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section id="connect" class="pt-20 sm:pt-32 pb-16 sm:pb-20 opacity-0 animate-section">
        <div class="max-w-2xl space-y-12">
          <div class="space-y-6">
            <h2 class="text-4xl sm:text-5xl font-light tracking-tight">Let's <span class="text-brand">Connect</span></h2>

            <p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
              Always interested in backend engineering opportunities, architecture discussions, and reliability-focused collaborations. Based in Kochi, Kerala.
            </p>

            <a
              href="mailto:chandranrakash@gmail.com"
              class="inline-flex items-center gap-3 px-6 py-3 rounded-lg border border-brand bg-brand text-white transition-all duration-300 group hover:bg-[color:var(--brand-hover)] shadow-[0_0_24px_-12px_var(--brand-glow)] hover:shadow-[0_0_28px_-10px_var(--brand-glow)]"
            >
              <span class="font-medium">Get in touch</span>
              <svg
                class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>

          <div class="pt-8 border-t border-border/40 space-y-6">
            <div class="text-xs text-muted-foreground font-mono tracking-widest">ELSEWHERE</div>

            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {socialLinks.map((social) => (
                <a
                  href={social.url}
                  class="group px-4 py-3 border border-border/40 rounded-lg hover:border-border transition-all duration-300 hover:bg-muted/20 text-sm text-muted-foreground hover:text-foreground"
                >
                  {social.name}
                </a>
              ))}
            </div>

          </div>
        </div>
      </section>

      <Footer />

      <div id="leadModal" data-leads-api-url={leadsApiUrl} data-turnstile-site-key={turnstileSiteKey} class="fixed inset-0 z-50 hidden pointer-events-none" aria-hidden="true">
        <div id="leadModalBackdrop" class="absolute inset-0 bg-background/75 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
        <div class="relative z-10 min-h-screen px-4 py-6 sm:py-12 flex items-center justify-center">
          <div id="leadModalPanel" class="w-full max-w-md rounded-2xl border border-border/60 bg-background/70 backdrop-blur-xl p-5 sm:p-6 shadow-[0_0_40px_-20px_var(--brand-glow)] space-y-5 opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95 transition-all duration-300">
            <div class="flex items-center justify-between gap-4">
              <h3 class="text-xl font-medium tracking-tight">📄 Get Resume</h3>
              <button id="closeLeadModal" type="button" aria-label="Close modal" class="p-2 rounded border border-border/40 hover:border-border transition-colors duration-300 text-muted-foreground hover:text-foreground">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M18 6l-12 12" />
                </svg>
              </button>
            </div>

            <p class="text-sm text-muted-foreground">Share your details and why you need the resume. I’ll send the download link to your inbox.</p>

            <form id="leadForm" class="space-y-4" autocomplete="off">
              <div class="space-y-2">
                <label for="leadName" class="text-sm text-muted-foreground">Name <span class="text-xs text-muted-foreground/80">(Optional)</span></label>
                <input id="leadName" name="name" type="text" maxlength="100" class="w-full rounded-lg border border-border/50 bg-background/60 px-3 py-2.5 text-sm text-foreground outline-none focus:border-brand" />
              </div>

              <div class="space-y-2">
                <label for="leadEmail" class="text-sm text-muted-foreground">Email <span class="text-xs text-muted-foreground/80">(Required)</span></label>
                <input id="leadEmail" name="email" type="email" required class="w-full rounded-lg border border-border/50 bg-background/60 px-3 py-2.5 text-sm text-foreground outline-none focus:border-brand" />
              </div>

              <div class="space-y-2">
                <label for="leadReason" class="text-sm text-muted-foreground">Reason for download <span class="text-xs text-muted-foreground/80">(Required)</span></label>
                <textarea
                  id="leadReason"
                  name="reason"
                  required
                  maxlength="280"
                  rows="3"
                  placeholder="Example: I want to review your backend experience for an open role."
                  class="w-full resize-none rounded-lg border border-border/50 bg-background/60 px-3 py-2.5 text-sm text-foreground outline-none focus:border-brand"
                ></textarea>
              </div>

              {turnstileSiteKey ? (
                <div class="space-y-2">
                  <p class="text-sm text-muted-foreground">Captcha <span class="text-xs text-muted-foreground/80">(Required)</span></p>
                  <div id="turnstileWidget" class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
                </div>
              ) : (
                <p class="text-sm text-foreground">Captcha is unavailable. Please configure Turnstile.</p>
              )}

              <p id="leadFormMessage" class="text-sm text-muted-foreground" role="status" aria-live="polite"></p>

              <button id="leadSubmitBtn" type="submit" class="w-full px-5 py-2.5 rounded-lg border border-brand bg-brand text-sm text-white transition-all duration-300 hover:bg-[color:var(--brand-hover)] disabled:opacity-60 disabled:cursor-not-allowed">
                Send Resume Link
              </button>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>
  <!-- Section reveal animation -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-fade-in-up');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -10% 0px' }
    );

    document.querySelectorAll('.animate-section').forEach((section) => {
      observer.observe(section);
    });

    const leadModal = document.getElementById('leadModal') as HTMLDivElement | null;
    const openLeadModalButtons = Array.from(
      document.querySelectorAll('[data-open-lead-modal], #openLeadModal')
    ) as HTMLButtonElement[];
    const closeLeadModalButton = document.getElementById('closeLeadModal') as HTMLButtonElement | null;
    const leadModalBackdrop = document.getElementById('leadModalBackdrop') as HTMLDivElement | null;
    const leadModalPanel = document.getElementById('leadModalPanel') as HTMLDivElement | null;
    const leadForm = document.getElementById('leadForm') as HTMLFormElement | null;
    const leadFormMessage = document.getElementById('leadFormMessage') as HTMLParagraphElement | null;
    const leadSubmitButton = document.getElementById('leadSubmitBtn') as HTMLButtonElement | null;
    const leadNameInput = document.getElementById('leadName') as HTMLInputElement | null;
    const turnstileWidget = document.getElementById('turnstileWidget') as HTMLDivElement | null;
    const leadsApiUrl = leadModal?.getAttribute('data-leads-api-url')?.trim() ?? '';
    const turnstileSiteKey = leadModal?.getAttribute('data-turnstile-site-key')?.trim() ?? '';
    let turnstileLoader: Promise<void> | null = null;
    let isLeadModalClosing = false;
    let leadModalCloseTimeout: number | null = null;

    const loadTurnstile = () => {
      if (!turnstileSiteKey || !turnstileWidget) {
        return Promise.resolve();
      }

      const existing = (window as Window & {
        turnstile?: { render: (target: HTMLElement) => string };
      }).turnstile;

      if (existing) {
        return Promise.resolve();
      }

      if (turnstileLoader) {
        return turnstileLoader;
      }

      turnstileLoader = new Promise<void>((resolve, reject) => {
        const script = document.createElement('script');
        script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
        script.async = true;
        script.defer = true;
        script.onload = () => {
          const loaded = (window as Window & {
            turnstile?: { render: (target: HTMLElement) => string };
          }).turnstile;

          if (loaded) {
            loaded.render(turnstileWidget);
          }

          resolve();
        };
        script.onerror = () => reject(new Error('Failed to load captcha.'));
        document.head.appendChild(script);
      });

      return turnstileLoader;
    };

    const openLeadModal = () => {
      if (!leadModal) return;

      if (leadModalCloseTimeout !== null) {
        window.clearTimeout(leadModalCloseTimeout);
        leadModalCloseTimeout = null;
      }

      isLeadModalClosing = false;
      leadModal.classList.remove('hidden');
      leadModal.classList.remove('pointer-events-none');
      leadModal.setAttribute('aria-hidden', 'false');

      leadModalBackdrop?.classList.add('opacity-0');
      leadModalBackdrop?.classList.remove('opacity-100');
      leadModalPanel?.classList.add('opacity-0', 'translate-y-4', 'sm:scale-95');
      leadModalPanel?.classList.remove('opacity-100', 'translate-y-0', 'sm:scale-100');

      leadModalPanel?.getBoundingClientRect();

      requestAnimationFrame(() => {
        leadModalBackdrop?.classList.remove('opacity-0');
        leadModalBackdrop?.classList.add('opacity-100');
        leadModalPanel?.classList.remove('opacity-0', 'translate-y-4', 'sm:scale-95');
        leadModalPanel?.classList.add('opacity-100', 'translate-y-0', 'sm:scale-100');
      });

      loadTurnstile().catch(() => {
        if (leadFormMessage) {
          leadFormMessage.className = 'text-sm text-brand bg-brand-soft border border-brand rounded-md px-3 py-2';
          leadFormMessage.textContent = 'Captcha is unavailable. Please try again later.';
        }
      });

      setTimeout(() => leadNameInput?.focus(), 80);
    };

    const closeLeadModal = () => {
      if (!leadModal || isLeadModalClosing) return;
      isLeadModalClosing = true;
      leadModalBackdrop?.classList.add('opacity-0');
      leadModalBackdrop?.classList.remove('opacity-100');
      leadModalPanel?.classList.add('opacity-0', 'translate-y-4', 'sm:scale-95');
      leadModalPanel?.classList.remove('opacity-100', 'translate-y-0', 'sm:scale-100');
      leadModal.classList.add('pointer-events-none');

      leadModalCloseTimeout = window.setTimeout(() => {
        leadModal.classList.add('hidden');
        leadModal.setAttribute('aria-hidden', 'true');
        isLeadModalClosing = false;
        leadModalCloseTimeout = null;
      }, 300);

      if (leadFormMessage) {
        leadFormMessage.textContent = '';
      }

      const turnstile = (window as Window & {
        turnstile?: { reset: (widget?: string | HTMLElement) => void };
      }).turnstile;
      if (turnstile && turnstileWidget) {
        turnstile.reset(turnstileWidget);
      }
    };

    openLeadModalButtons.forEach((button) => {
      button.addEventListener('click', openLeadModal);
    });
    closeLeadModalButton?.addEventListener('click', closeLeadModal);
    leadModalBackdrop?.addEventListener('click', closeLeadModal);
    leadModal?.addEventListener('click', (event) => {
      const target = event.target as Node | null;
      if (leadModalPanel && target && !leadModalPanel.contains(target)) {
        closeLeadModal();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && leadModal && !leadModal.classList.contains('hidden')) {
        closeLeadModal();
      }
    });

    leadForm?.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!leadFormMessage || !leadSubmitButton) return;

      if (!leadsApiUrl) {
        leadFormMessage.className = 'text-sm text-brand bg-brand-soft border border-brand rounded-md px-3 py-2';
        leadFormMessage.textContent = 'Form is unavailable right now. Please try again later.';
        return;
      }

      if (!turnstileSiteKey) {
        leadFormMessage.className = 'text-sm text-brand bg-brand-soft border border-brand rounded-md px-3 py-2';
        leadFormMessage.textContent = 'Captcha is unavailable. Please try again later.';
        return;
      }

      const formData = new FormData(leadForm);
      const name = String(formData.get('name') ?? '').trim();
      const email = String(formData.get('email') ?? '').trim();
      const reason = String(formData.get('reason') ?? '').trim();
      const turnstileToken = String(formData.get('cf-turnstile-response') ?? '').trim();

      if (!turnstileToken) {
        leadFormMessage.className = 'text-sm text-brand bg-brand-soft border border-brand rounded-md px-3 py-2';
        leadFormMessage.textContent = 'Please complete the captcha verification.';
        return;
      }

      leadSubmitButton.setAttribute('disabled', 'true');
      leadFormMessage.className = 'text-sm text-muted-foreground';
      leadFormMessage.textContent = 'Sending...';

      try {
        const response = await fetch(leadsApiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            name,
            email,
            reason,
            consent: true,
            turnstileToken,
          }),
        });

        const data = (await response.json().catch(() => ({}))) as { error?: string };

        if (!response.ok) {
          const message = typeof data?.error === 'string' ? data.error : 'Failed to submit. Please try again.';
          throw new Error(message);
        }

        leadFormMessage.className = 'text-sm text-brand';
        leadFormMessage.textContent = 'Success! Check your email for the resume link.';
      } catch (error) {
        leadFormMessage.className = 'text-sm text-brand bg-brand-soft border border-brand rounded-md px-3 py-2';
        leadFormMessage.textContent = error instanceof Error ? error.message : 'Something went wrong. Please try again.';
      } finally {
        leadSubmitButton.removeAttribute('disabled');
      }
    });
  </script>
</BaseLayout>
