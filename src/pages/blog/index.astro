---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogPagination from '../../components/BlogPagination.astro';
import { getSortedPosts } from '../../lib/hashnode/client';
import { formatMonthYear } from '../../lib/date/format-date';

const PAGE_SIZE = 6;
const allPosts = await getSortedPosts();
const posts = allPosts.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));

const featuredCount = allPosts.filter((post) => post.featured).length;
---

<BaseLayout 
  title="Blog — Akash R Chandran" 
  description="Notes on backend engineering: APIs, data systems, reliability, and production operations."
>
  <Header />

  <main class="min-h-screen bg-background text-foreground pt-32">
    <div class="max-w-6xl mx-auto px-6 sm:px-8">
      <div class="space-y-12 sm:space-y-16">
        <!-- Header -->
        <div class="space-y-4">
          <h1 class="text-5xl sm:text-6xl font-light tracking-tight">Blog</h1>
          <p class="text-lg text-muted-foreground max-w-2xl leading-relaxed">
            Notes on backend engineering: APIs, data systems, reliability, and production operations.
          </p>

          {featuredCount > 0 ? (
            <p class="text-xs text-muted-foreground font-mono tracking-widest">
              {featuredCount} FEATURED POST{featuredCount > 1 ? 'S' : ''}
            </p>
          ) : null}
        </div>

        <!-- Blog Posts List -->
        <div class="grid gap-6 md:grid-cols-2">
          {posts.length ? (
            posts.map((post) => (
              <a href={`/blog/${post.slug}`} class="group block">
                <article class="h-full p-6 sm:p-7 border border-border/40 rounded-xl hover:border-border transition-all duration-300 hover:bg-muted/20 space-y-4">
                  {post.coverImage?.url ? (
                    <img
                      src={post.coverImage.url}
                      alt={post.title}
                      loading="lazy"
                      class="w-full aspect-[16/9] object-cover rounded-xl border border-border/40"
                    />
                  ) : null}

                  <div class="space-y-3">
                    <div class="flex items-center justify-between gap-3 text-xs text-muted-foreground font-mono">
                      <span>{formatMonthYear(post.publishedAt)}</span>
                      <span>{post.readTimeInMinutes} min</span>
                    </div>

                    <div class="flex items-start justify-between gap-3">
                      <h2 class="text-xl sm:text-2xl font-medium group-hover:text-muted-foreground transition-colors duration-300 leading-tight">
                        {post.title}
                      </h2>
                      {post.featured ? (
                        <span class="px-2.5 py-1 text-[10px] font-medium text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-950/30 rounded-full shrink-0">
                          Featured
                        </span>
                      ) : null}
                    </div>

                    <p class="text-muted-foreground text-sm leading-relaxed">
                      {post.brief || post.subtitle || 'Read the full article for implementation details and engineering trade-offs.'}
                    </p>

                    <div class="flex flex-wrap gap-3 items-center pt-1">
                      {post.tags?.[0]?.name ? (
                        <span class="px-2.5 py-1 text-xs text-muted-foreground bg-muted/20 rounded-full">
                          {post.tags[0].name}
                        </span>
                      ) : null}
                      <span class="text-xs text-muted-foreground group-hover:text-foreground transition-colors duration-300">Read →</span>
                    </div>
                  </div>
                </article>
              </a>
            ))
          ) : (
            <div class="md:col-span-2 p-6 sm:p-8 border border-border/40 rounded-xl text-sm text-muted-foreground">
              No Hashnode posts found. Set HASHNODE_PUBLICATION_HOST to load your publication content.
            </div>
          )}
        </div>

        <BlogPagination currentPage={1} totalPages={totalPages} />

        <!-- Back link -->
        <div class="pb-16">
          <a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors duration-300">
            ← Back to home
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
