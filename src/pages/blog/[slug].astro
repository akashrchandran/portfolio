---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPost, getSortedPosts } from '../../lib/hashnode/client';
import { formatMonthYear } from '../../lib/date/format-date';

interface AdjacentPost {
  slug: string;
  title: string;
}

interface StaticPathProps {
  prevPost: AdjacentPost | null;
  nextPost: AdjacentPost | null;
}

export async function getStaticPaths() {
  const posts = await getSortedPosts();

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      prevPost: index > 0 ? { slug: posts[index - 1].slug, title: posts[index - 1].title } : null,
      nextPost:
        index < posts.length - 1
          ? { slug: posts[index + 1].slug, title: posts[index + 1].title }
          : null,
    } satisfies StaticPathProps,
  }));
}

const { slug } = Astro.params;
const { prevPost, nextPost } = Astro.props as StaticPathProps;
const post = slug ? await getPost(slug) : null;
const blogCanonicalOrigin = 'https://blog.akashrchandran.in';

if (!post) {
  throw new Error('Hashnode post not found. Check HASHNODE_PUBLICATION_HOST and slug values.');
}
---

<BaseLayout
  title={`${post.title} — Akash R Chandran`}
  description={post.brief || post.subtitle || 'Backend engineering article'}
  canonicalUrl={`${blogCanonicalOrigin}/${post.slug}`}
  ogType="article"
  publishedTime={post.publishedAt}
  openGraphImage={post.coverImage?.url}
  openGraphImageAlt={post.title}
>
  <Header />

  <main class="min-h-screen bg-background text-foreground pt-32">
    <div class="max-w-3xl mx-auto px-6 sm:px-8">
      <div class="space-y-8 sm:space-y-12">
        <div class="space-y-4">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors duration-300 group"
          >
            <svg
              class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform duration-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to blog
          </a>

          <div class="space-y-3">
            <h1 class="text-4xl sm:text-5xl font-light tracking-tight leading-tight">{post.title}</h1>

            <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
              <span>{formatMonthYear(post.publishedAt)}</span>
              <span>•</span>
              <span>{post.readTimeInMinutes} min</span>
              {post.tags?.[0]?.name ? (
                <>
                  <span>•</span>
                  <span class="px-2 py-0.5 bg-muted/20 rounded-full">{post.tags[0].name}</span>
                </>
              ) : null}
            </div>
          </div>
        </div>

        {post.coverImage?.url ? (
          <img
            src={post.coverImage.url}
            alt={post.title}
            class="w-full rounded-xl border border-border/40 object-cover"
            loading="lazy"
          />
        ) : null}

        <article class="prose prose-invert max-w-none">
          <div class="space-y-6 text-muted-foreground leading-relaxed [&_h1]:text-3xl [&_h1]:font-light [&_h1]:text-foreground [&_h2]:text-2xl [&_h2]:font-light [&_h2]:text-foreground [&_h3]:text-xl [&_h3]:font-medium [&_h3]:text-foreground [&_a]:text-foreground [&_a]:underline [&_strong]:text-foreground">
            <Fragment set:html={post.content?.html || '<p>This post is currently unavailable.</p>'} />
          </div>
        </article>

        <div class="pt-12 border-t border-border/40 space-y-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {prevPost ? (
              <a href={`/blog/${prevPost.slug}`} class="group">
                <div class="space-y-2 p-4 border border-border/40 rounded-lg hover:border-border transition-all duration-300 hover:bg-muted/20">
                  <div class="text-xs text-muted-foreground">← Previous</div>
                  <div class="font-medium group-hover:text-muted-foreground transition-colors duration-300">
                    {prevPost.title}
                  </div>
                </div>
              </a>
            ) : (
              <div />
            )}

            {nextPost ? (
              <a href={`/blog/${nextPost.slug}`} class="group">
                <div class="space-y-2 p-4 border border-border/40 rounded-lg hover:border-border transition-all duration-300 hover:bg-muted/20 text-right">
                  <div class="text-xs text-muted-foreground">Next →</div>
                  <div class="font-medium group-hover:text-muted-foreground transition-colors duration-300">
                    {nextPost.title}
                  </div>
                </div>
              </a>
            ) : (
              <div />
            )}
          </div>

          <div class="text-center pb-16">
            <a
              href="/blog"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm text-muted-foreground hover:text-foreground transition-colors duration-300"
            >
              ← Back to all posts
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
